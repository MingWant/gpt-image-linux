DEFAULT_API_URL=
DEFAULT_API_KEY=
DEFAULT_API_PATH=/v1/images/generations
DEFAULT_RESPONSES_MODEL=gpt-5.4
APP_VERSION=
GITHUB_REPO=Z1rconium/gpt-image-linux
PANEL_PATH=
ACCESS_KEY=
ALLOW_UNAUTHENTICATED=false
IP_ALLOWLIST=
TRUST_PROXY_HEADERS=false
MAX_FILE_SIZE_MB=50
PYTHON_BASE_IMAGE=python:3.11-slim

# Security settings
ACCESS_COOKIE_SECURE=auto
ACCESS_MAX_FAILURES=5
ACCESS_LOCKOUT_SECONDS=300
UPSTREAM_HOST_ALLOWLIST=
UPSTREAM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36
UPSTREAM_ORIGIN=https://myapiserverurl
UPSTREAM_REFERER=https://myapiserverurl
UPSTREAM_EXTRA_HEADERS={"sec-ch-ua":"\"Google Chrome\";v=\"145\", \"Not:A-Brand\";v=\"8\", \"Chromium\";v=\"145\"","sec-ch-ua-mobile":"?0"}
WEBHOOK_HOST_ALLOWLIST=
WEBHOOK_SIGNING_SECRET=
WEBHOOK_TIMEOUT_SECONDS=5
WEBHOOK_MAX_ATTEMPTS=3
